{
  "id": "dark_green_fold",
  "name": "Dark Green Fold",
  "width": 1000,
  "height": 600,
  "clipRadius": 30,
  "paintLayers": [
    {
      "type": "rect",
      "fill": "#002B2E"
    },
    {
      "type": "stripes",
      "count": 60,
      "step": 17,
      "color": "#FFFFFF05",
      "strokeWidth": 1
    },
    {
      "type": "fold",
      "foldX": 650,
      "foldColor": "#E8DFC8"
    },
    {
      "type": "fold_shadow",
      "foldX": 650,
      "color": "#00000033",
      "blurSigma": 12
    },
    {
      "type": "fold_highlight",
      "foldX": 652,
      "color": "#FFFFFF14",
      "strokeWidth": 3
    },
    {
      "type": "line",
      "x1": 30, "y1": 550, "x2": 600, "y2": 550,
      "stroke": "#E8DFC880",
      "strokeWidth": 2
    },
    {
      "type": "diamonds",
      "count": 3,
      "startX": 100, "spacing": 200,
      "y": 550, "size": 4,
      "color": "#E8DFC8"
    }
  ],
  "widgetLayers": [
    {
      "type": "image",
      "field": "profileImagePath",
      "x": 160, "y": 140, "size": 100,
      "shape": "circle",
      "rtlX": 600
    },
    {
      "type": "text",
      "field": "fullName",
      "x": 160, "y": 310,
      "fontSize": 30, "color": "#FFFFFF", "fontWeight": "700",
      "maxLines": 1,
      "rtlX": 100
    },
    {
      "type": "text",
      "field": "companyName",
      "x": 160, "y": 346,
      "fontSize": 14, "color": "#FFFFFF99", "fontWeight": "500",
      "maxLines": 1,
      "rtlX": 100
    },
    {
      "type": "text",
      "field": "tagline",
      "x": 160, "y": 366,
      "fontSize": 13, "color": "#E8DFC8", "fontWeight": "400",
      "maxLines": 1,
      "rtlX": 100
    },
    {
      "type": "text",
      "field": "jobTitle",
      "x": 160, "y": 386,
      "fontSize": 16, "color": "#FFFFFFB3", "fontWeight": "400",
      "maxLines": 1,
      "rtlX": 100
    },
    {
      "type": "contact_on_fold",
      "x": 960, "y": 60,
      "fields": ["mobileNumber", "mobileNumber2", "email", "website"],
      "colors": ["#002B2E", "#002B2EB3", "#002B2EB3", "#002B2EB3"],
      "fontSizes": [13, 12, 12, 12],
      "fontWeights": ["500", "400", "400", "400"]
    },
    {
      "type": "social_dots",
      "x": 945, "y": 270,
      "fields": ["linkedin", "instagram", "facebook", "x"],
      "colors": ["#0A66C2", "#E4405F", "#1877F2", "#000000"],
      "spacing": 14
    }
  ]
}
